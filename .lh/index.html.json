            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"pt-BR\">\r\n<head>\r\n\r\n    <!-- Google tag (gtag.js) -->\r\n<script async src=\"https://www.googletagmanager.com/gtag/js?id=G-RPYW10FKXD\"></script>\r\n<script>\r\n  window.dataLayer = window.dataLayer || [];\r\n  function gtag(){dataLayer.push(arguments);}\r\n  gtag('js', new Date());\r\n\r\n  gtag('config', 'G-RPYW10FKXD');\r\n\r\n</script>\r\n\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>ReCiclo - Jogo Educativo</title>\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <link rel=\"stylesheet\" href=\"style.css\">\r\n</head>\r\n<body>\r\n    <div class=\"container\">\r\n        <div class=\"bubbles\">\r\n            <div class=\"bubble\"></div>\r\n            <div class=\"bubble\"></div>\r\n            <div class=\"bubble\"></div>\r\n            <div class=\"bubble\"></div>\r\n            <div class=\"bubble\"></div>\r\n        </div>\r\n        \r\n        <header>\r\n            <div class=\"logo\">\r\n                <i class=\"fas fa-recycle\"></i>\r\n                <div>\r\n                    <h1>ReCiclo</h1>\r\n                    <div class=\"subtitle\">Jogo educativo sobre reciclagem e vida na água</div>\r\n                </div>\r\n            </div>\r\n            <div class=\"water-wave\"></div>\r\n        </header>\r\n        \r\n        <div class=\"content\">\r\n            <!-- Tela inicial -->\r\n            <div class=\"start-screen\" id=\"start-screen\">\r\n                <h2>Teste seus conhecimentos sobre sustentabilidade!</h2>\r\n                <p>O jogo ReCiclo apresenta 15 perguntas sobre reciclagem, conservação da água e vida marinha, temas relacionados aos Objetivos de Desenvolvimento Sustentável (ODS) da ONU.</p>\r\n                \r\n                <div class=\"ods-logos\">\r\n                    <div class=\"ods-logo ods-12\">12</div>\r\n                    <div class=\"ods-logo ods-14\">14</div>\r\n                </div>\r\n                \r\n                <p>ODS 12: Consumo e produção responsáveis<br>ODS 14: Vida na água</p>\r\n                \r\n                <button class=\"btn\" id=\"start-btn\">\r\n                    <i class=\"fas fa-play\"></i> Iniciar Jogo\r\n                </button>\r\n            </div>\r\n            \r\n            <!-- Tela do jogo -->\r\n            <div class=\"game-screen\" id=\"game-screen\">\r\n                <div class=\"question-container\">\r\n                    <div class=\"question-header\">\r\n                        <div>PERGUNTA <span id=\"current-question\">1</span>/15</div>\r\n                        <div>PONTOS: <span id=\"score\">0</span></div>\r\n                    </div>\r\n                    \r\n                    <div class=\"question-text\" id=\"question-text\">\r\n                        Carregando pergunta...\r\n                    </div>\r\n                    \r\n                    <div class=\"options-container\" id=\"options-container\">\r\n                        \r\n                    </div>\r\n                    \r\n                    <div class=\"feedback\" id=\"feedback\">\r\n                        <!-- Feedback será adicionado por JavaScript -->\r\n                    </div>\r\n                    \r\n                    <div class=\"next-btn-container\" id=\"next-btn-container\" style=\"display: none;\">\r\n                        <button class=\"btn-next\" id=\"next-btn\">\r\n                            <i class=\"fas fa-arrow-right\"></i> Próxima Pergunta\r\n                        </button>\r\n                    </div>\r\n                </div>\r\n                \r\n                <div class=\"progress-container\">\r\n                    <div class=\"progress-bar\" id=\"progress-bar\"></div>\r\n                </div>\r\n                \r\n                <div class=\"footer-note\">\r\n                    Ajude a proteger nossos oceanos e promover a reciclagem!\r\n                </div>\r\n            </div>\r\n            \r\n            <!-- Tela de resultados -->\r\n            <div class=\"result-screen\" id=\"result-screen\">\r\n                <h2>Resultado Final</h2>\r\n                \r\n                <div class=\"score-circle\" id=\"score-circle\">\r\n                    <div class=\"score-inner\">\r\n                        <div class=\"score-value\" id=\"final-score\">0</div>\r\n                        <div class=\"score-text\">PONTOS</div>\r\n                    </div>\r\n                    <i class=\"fas fa-tint water-icon\"></i>\r\n                    <i class=\"fas fa-tint water-icon\"></i>\r\n                    <i class=\"fas fa-tint water-icon\"></i>\r\n                    <i class=\"fas fa-tint water-icon\"></i>\r\n                </div>\r\n                \r\n                <div class=\"result-message\" id=\"result-message\"></div>\r\n                \r\n                <button class=\"btn\" id=\"restart-btn\">\r\n                    <i class=\"fas fa-redo\"></i> Jogar Novamente\r\n                </button>\r\n                \r\n                <div class=\"footer-note\">\r\n                    Compartilhe esse jogo e ajude a conscientizar mais pessoas!\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    \r\n    <!-- Elementos decorativos -->\r\n    <div class=\"fish\">🐠</div>\r\n    <div class=\"fish\" style=\"top: 30%; animation-delay: 5s; animation-duration: 30s;\">🐟</div>\r\n    <div class=\"fish\" style=\"top: 70%; animation-delay: 10s; animation-duration: 35s;\">🐡</div>\r\n    <div class=\"turtle\">🐢</div>\r\n    \r\n    <script src=\"script.js\"></script>\r\n</body>\r\n</html>"
